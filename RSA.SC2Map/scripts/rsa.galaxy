//============
// rsa.galaxy 
//============

static const string PUBLIC_KEY_N = "";
static const string PUBLIC_KEY_E = "65537";

// Generates a hash of the original message
static string MessageHash(string msg, int player);
// Decrypts RSA hash
static string RSADecrypt(string msg, structref<BigNum_t> base, structref<BigNum_t> exp, structref<BigNum_t> mod, structref<BigNum_t> result);
// Verifies the RSA signature
bool RSAVerifySignature(string msg, int player);

static string MessageHash(string msg, int player) {
    string acc = PlayerHandle(player); // get player handle
    if( acc == "" ) { acc = "SC2E-TEST-ACCOUNT"; } // For offline editor testing
    return HexToDecimal(SHA1HashString(SplitStringAt(msg, "|", 1) + "|" + acc)); // Return msg hash in decimal format
}

static string RSADecrypt(string msg, structref<BigNum_t> base, structref<BigNum_t> exp, structref<BigNum_t> mod, structref<BigNum_t> result) {
    StringToBigNum(SplitStringAt(msg, "|", 3), base); // convert encrypted hash to array
    StringToBigNum(PUBLIC_KEY_E, exp); // convert public key exponent to array
    StringToBigNum(PUBLIC_KEY_N, mod); // convert public key modulus to array
    BigNumModExp(base, exp, mod, result); // function for decrypting

    return BigNumToString(result); // convert decrypted hash to string
}

bool RSAVerifySignature(string msg, int player) {
    BigNum_t base;
    BigNum_t exp;
    BigNum_t mod;
    BigNum_t result;

    string decoded = DecodeBase64(msg); // decode chat message
    string messageHash = MessageHash(decoded, player); // hash original message
    string decryptedHash = RSADecrypt(decoded, base, exp, mod, result); // decrypted rsa hash

    return StringEqual(decryptedHash, messageHash, true); // compare decrypted hash & original msg hash
}

// Encoded string for editor test
// -m {chat msg} -m 
bool gt_DecryptMessage (bool a, bool b) {
    string encryptedMsg = StringWord(EventChatMessage(false), 2);

    if (a) { if (encryptedMsg == "") { return false; } }
    // Determine if signature is valid
    if (RSAVerifySignature(encryptedMsg, EventPlayer())) { 
        UIDisplayMessage(PlayerGroupSingle(EventPlayer()), c_messageAreaDebug, StringToText("Signature Passed"));
    } else { 
        UIDisplayMessage(PlayerGroupSingle(EventPlayer()), c_messageAreaDebug, StringToText("Signature Failed")); 
    }

    return true;
}

void DecryptMessageInit() {
    trigger t = TriggerCreate("gt_DecryptMessage");
    TriggerAddEventChatMessage(t, c_playerAny, "-m", false);
}
